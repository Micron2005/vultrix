// Noor Auto Repair / QNA shop software
// Phase 1: customers, vehicles, repair orders, invoice PDFs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime uses the Neon -pooler endpoint (pgbouncer, transaction mode) so
  // serverless functions reuse pooled connections cleanly.
  url       = env("DATABASE_URL")
  // Migrations (prisma migrate deploy) MUST use the direct (non-pooled)
  // endpoint — pgbouncer in transaction mode can't hold Postgres advisory
  // locks, so migrate deploy hangs and times out via the pooler.
  // Falls back to DATABASE_URL when unset (e.g. local dev).
  directUrl = env("DIRECT_DATABASE_URL")
}

model Customer {
  id          String  @id @default(cuid())
  // External id from a prior system (Identifix export Id). Lets a re-run of
  // CSV import update the existing record instead of creating a duplicate.
  externalId  String?
  // INDIVIDUAL | BUSINESS — controls which tab the record lives in and how
  // A/R is split on the dashboard.
  type        String  @default("INDIVIDUAL")
  firstName   String
  lastName    String
  companyName String?
  email       String?
  phone       String?
  altPhone    String?
  street      String?
  city        String?
  state       String?
  zip         String?
  notes       String?

  // Customer portal access. Token is a non-guessable random string; if null,
  // the public /p/[token] route doesn't exist for this customer.
  portalToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles     Vehicle[]
  repairOrders RepairOrder[]
  appointments Appointment[]

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, externalId])
  @@index([lastName, firstName])
  @@index([type])
  @@index([orgId])
}

model Vehicle {
  id         String   @id @default(cuid())
  // External id from a prior system (Identifix vehicle Id). Lets a re-run of
  // CSV import update the existing record instead of creating a duplicate.
  externalId String?
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  serviceLogs ServiceLog[]

  vin          String?
  year         Int?
  make         String?
  model        String?
  trim         String?
  engine       String?
  transmission String?
  drivetrain   String?
  bodyStyle    String?
  color        String?
  licensePlate String?
  licenseState String?
  mileage      Int?
  notes        String?

  // NHTSA recall data cache. Raw JSON response; refreshed on demand.
  recallsJson      String?
  recallsFetchedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repairOrders RepairOrder[]
  appointments Appointment[]

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, externalId])
  @@index([customerId])
  @@index([vin])
  @@index([licensePlate])
  @@index([orgId])
}

model RepairOrder {
  id       String @id @default(cuid())
  roNumber Int

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  status String @default("ESTIMATE") // ESTIMATE | IN_PROGRESS | COMPLETED | INVOICED | PAID | CANCELLED

  openedAt   DateTime  @default(now())
  promisedAt DateTime?
  closedAt   DateTime?

  // Lifecycle timestamps (set by transitions)
  approvedAt  DateTime? // customer approved the estimate
  startedAt   DateTime? // work began (moved to IN_PROGRESS)
  completedAt DateTime? // work finished
  invoicedAt  DateTime? // invoice generated
  paidAt      DateTime? // payment received
  cancelledAt DateTime? // RO cancelled
  clearedAt   DateTime? // paid ticket cleared/closed out of active list
  deletedAt   DateTime? // soft delete: in Trash, hidden from all normal views

  mileageIn  Int?
  mileageOut Int?

  complaint  String? // customer complaint (3 C's)
  cause      String? // cause
  correction String? // correction
  notes      String?

  taxRate  Float @default(0)
  discount Float @default(0)

  // Shareable estimate link. Token is a non-guessable random string; if null,
  // the public /e/[token] route doesn't exist for this RO.
  shareToken           String?   @unique
  estimateDeclinedAt   DateTime?
  customerResponseNote String?

  // Customer signature captured at approval (useful for insurance claims).
  signatureDataUrl String?   // base64 PNG of the drawn signature
  signatureName    String?   // typed name of the signer
  signedAt         DateTime? // when the signature was captured

  jobs              Job[]
  laborLines        LaborLine[]
  partLines         PartLine[]
  feeLines          FeeLine[]
  appointments      Appointment[]
  payments          Payment[]
  shopFeeExclusions RepairOrderShopFeeExclusion[]
  photos            RepairOrderPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, roNumber])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([openedAt])
  @@index([orgId])
  @@index([orgId, deletedAt])
}

model Job {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  name      String
  sortOrder Int    @default(0)

  // Internal tech notes for this job (not shown to the customer).
  notes String?

  // Per-job approval on estimates: PENDING | APPROVED | DECLINED
  approvalStatus String    @default("PENDING")
  approvedAt     DateTime?
  declinedAt     DateTime?
  customerNote   String?

  laborLines LaborLine[]
  partLines  PartLine[]
  feeLines   FeeLine[]

  createdAt DateTime @default(now())

  @@index([repairOrderId])
}

model Payment {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  amount    Float
  method    String // CASH | CARD | CHECK | TRANSFER | OTHER
  reference String? // check # / auth # / last 4
  note      String?
  paidAt    DateTime @default(now())

  createdAt DateTime @default(now())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([repairOrderId])
  @@index([paidAt])
  @@index([orgId])
}

model LaborLine {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  description String
  hours       Float  @default(0)
  rate        Float  @default(0)
  sortOrder   Int    @default(0)

  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id])

  createdAt DateTime @default(now())

  @@index([repairOrderId])
  @@index([jobId])
  @@index([technicianId])
}

model Technician {
  id          String  @id @default(cuid())
  name        String
  initials    String?
  defaultRate Float? // optional — used as default when adding labor lines for this tech
  active      Boolean @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  laborLines LaborLine[]

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([active])
  @@index([name])
  @@index([orgId])
}

model PartLine {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  partNumber  String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0) // price charged to customer
  costPrice   Float? // what the shop paid (internal, optional)
  source      String? // where the part came from (supplier / vendor / store)
  sortOrder   Int     @default(0)

  // Optional link to inventory catalog. Free-text part lines (no catalog match) keep these null.
  partId     String?
  part       Part?       @relation(fields: [partId], references: [id], onDelete: SetNull)
  stockMoves StockMove[]

  createdAt DateTime @default(now())

  @@index([repairOrderId])
  @@index([jobId])
  @@index([partId])
}

// Flat-amount fees / charges on an RO (e.g. state inspection $20, shop supplies $5).
// Separate from labor and parts so invoices can show them as their own section.
// Fee lines are flat pass-through charges: included in the subtotal/total but
// NEVER taxed. Tax applies only to labor + parts (+ taxable shop fees).
model FeeLine {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  description String
  amount      Float  @default(0)
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())

  @@index([repairOrderId])
  @@index([jobId])
}

// Inventory catalog — parts the shop actually stocks.
// Free-form partLines (not tied to a Part) continue to work; the catalog is optional.
model Part {
  id          String  @id @default(cuid())
  partNumber  String?
  name        String
  description String?
  category    String? // free-form grouping: "Brakes", "Filters", "Oils & Fluids", "Cleaners"
  unit        String? // unit of measure: "each", "qt", "L", "oz", "can", "set"
  location    String? // physical bin/shelf, e.g. "Shelf B3" — also drives bin-QR scanning
  source      String? // default supplier / vendor
  costPrice   Float? // default cost (what shop pays)
  unitPrice   Float? // default price charged to customer

  qtyOnHand    Float @default(0)
  reorderLevel Float @default(0) // "low stock" if qtyOnHand <= reorderLevel

  // Optional fitment tags used by /vehicle-search. A part is shown for a given
  // picked vehicle when either (a) all fitment fields are null (universal), or
  // (b) the set fields match. Blank make/model = matches anything for that axis.
  fitsMake    String?
  fitsModel   String?
  fitsYearMin Int?
  fitsYearMax Int?

  notes    String?
  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partLines      PartLine[]
  stockMoves     StockMove[]
  cannedJobParts CannedJobPart[]

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, partNumber])
  @@index([name])
  @@index([category])
  @@index([location])
  @@index([archived])
  @@index([orgId])
}

// Every +/- to qtyOnHand is logged so the user can see why stock changed.
model StockMove {
  id     String @id @default(cuid())
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  // Positive = received / adjustment up; negative = used on RO / adjustment down.
  delta  Float
  reason String // RECEIVE | USE_RO | RESTOCK_RO | ADJUST | INITIAL
  note   String?

  // If the move was caused by a PartLine on an RO, link it here.
  partLineId String?
  partLine   PartLine? @relation(fields: [partLineId], references: [id], onDelete: SetNull)

  // True after a compensating move has been created to reverse this one.
  // Used by the scan-undo flow so a double-click or form resubmission
  // can't apply the inverse delta twice.
  undone Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([partId])
  @@index([createdAt])
}

model Appointment {
  id String @id @default(cuid())

  startsAt        DateTime
  durationMinutes Int      @default(60)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  // Once the appointment is converted into a repair order, link to it
  repairOrderId String?
  repairOrder   RepairOrder? @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)

  reason String // short label: "Oil change", "Brake inspection"
  notes  String?

  status String @default("SCHEDULED")
  // SCHEDULED | CONFIRMED | ARRIVED | COMPLETED | CANCELLED | NO_SHOW

  // Shareable reminder link. Non-guessable random string; /a/[token] route.
  shareToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([startsAt])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([orgId])
}

model ShopSetting {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  key          String
  value        String
  updatedAt    DateTime     @updatedAt

  @@unique([orgId, key])
  @@index([orgId])
}

// Knowledge base — your own repair notes keyed to year/make/model/engine.
// Think of these as your institutional memory / "hotline archive."
// Every field except title is optional so you can capture partial knowledge.
model RepairNote {
  id String @id @default(cuid())

  title   String
  // Vehicle targeting — all optional so a note can be make-wide, model-wide, or a tight YMM match.
  yearMin Int?
  yearMax Int?
  make    String?
  model   String?
  engine  String? // free-form (e.g. "2.4L K24A4", "3.5L V6")

  symptom            String? // "Squeal at low speed under light braking"
  diagnosis          String? // "Front brake pad backing glazed. Rotors in spec."
  fix                String? // "Replace front pads with ceramic. Clean & lube slide pins."
  partsNotes         String? // "Front pads — NAPA Adaptive One AD465. ~$42."
  laborHoursEstimate Float?

  tags String? // comma-separated: "brakes,noise,honda"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([make, model])
  @@index([yearMin])
  @@index([yearMax])
  @@index([orgId])
}

// Reusable job presets the shop does often (e.g. "Front brake service",
// "Oil change 5W-30"). Applying a preset to an RO copies its labor + parts
// lines onto the RO. The preset itself is unchanged when later edited on the RO.
model CannedJob {
  id          String  @id @default(cuid())
  name        String
  description String?
  category    String? // optional grouping: "Brakes", "Oil", "A/C"
  notes       String?
  archived    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  laborItems CannedJobLabor[]
  partItems  CannedJobPart[]
  feeItems   CannedJobFee[]

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([category])
  @@index([archived])
  @@index([orgId])
}

model CannedJobFee {
  id          String    @id @default(cuid())
  cannedJobId String
  cannedJob   CannedJob @relation(fields: [cannedJobId], references: [id], onDelete: Cascade)

  description String
  amount      Float  @default(0)
  sortOrder   Int    @default(0)

  @@index([cannedJobId])
}

model CannedJobLabor {
  id          String    @id @default(cuid())
  cannedJobId String
  cannedJob   CannedJob @relation(fields: [cannedJobId], references: [id], onDelete: Cascade)

  description String
  hours       Float  @default(0)
  rate        Float? // if null, falls back to shop default rate at apply time
  sortOrder   Int    @default(0)

  @@index([cannedJobId])
}

model CannedJobPart {
  id          String    @id @default(cuid())
  cannedJobId String
  cannedJob   CannedJob @relation(fields: [cannedJobId], references: [id], onDelete: Cascade)

  // Either free-text (partNumber + description + unitPrice) or a link into inventory.
  partNumber  String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float? // if null at apply time, 0 (or catalog price if partId set)
  sortOrder   Int     @default(0)

  partId String?
  part   Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([cannedJobId])
  @@index([partId])
}

// Shop-wide recurring service intervals (oil, brakes, tires, etc).
// Each interval is "due" after N miles and/or N months since the last time the
// service was performed on a given vehicle.  Either field may be null.
model ServiceInterval {
  id          String  @id @default(cuid())
  key         String  @unique // stable slug: "oil", "tire_rotation", ...
  label       String // display name: "Oil change"
  everyMiles  Int?
  everyMonths Int?
  sortOrder   Int     @default(0)
  archived    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs ServiceLog[]

  @@index([archived])
}

// Per-vehicle record of when a given service was last performed.  Populated
// automatically when an RO is marked Completed/Paid (heuristic on labor line
// descriptions) and manually via the "Mark service done" button.
model ServiceLog {
  id         String          @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  intervalId String
  interval   ServiceInterval @relation(fields: [intervalId], references: [id], onDelete: Cascade)

  performedAt DateTime @default(now())
  atMileage   Int?
  source      String   @default("manual") // manual | auto | baseline
  note        String?

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([intervalId])
  @@index([performedAt])
}

// Shop overhead / non-RO costs: rent, utilities, supplies, tools, vendor bills.
// Used by Reports for true P&L.
model Expense {
  id String @id @default(cuid())

  paidAt    DateTime @default(now())
  amount    Float // always positive; it's a cost (subtracted from revenue)
  category  String // RENT | UTILITIES | SUPPLIES | TOOLS | VEHICLE | INSURANCE | SOFTWARE | MISC
  vendor    String?
  reference String? // invoice # / check #
  method    String? // CASH | CARD | CHECK | TRANSFER | OTHER
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([paidAt])
  @@index([category])
  @@index([orgId])
}

// Identifix-style shop fees (e.g. Shop Supplies, Hazardous Materials) that
// auto-apply to every repair order. Each fee = min(maxCap, partsSubtotal *
// partsPercent + laborSubtotal * laborPercent). Rendered as its own line on
// invoices. Individual ROs can exclude specific fees via
// RepairOrderShopFeeExclusion (for waived fees on a given job).
model ShopFee {
  id String @id @default(cuid())

  name         String
  description  String?
  partsPercent Float   @default(0)
  laborPercent Float   @default(0)
  maxCap       Float? // null = no cap
  taxable      Boolean @default(false)
  active       Boolean @default(true)
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exclusions RepairOrderShopFeeExclusion[]

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([active])
  @@index([sortOrder])
  @@index([orgId])
}

// If a row exists here, that shop fee is EXCLUDED from that RO. Absent = fee
// applies. Composite PK so each (RO, fee) pair is unique.
model RepairOrderShopFeeExclusion {
  repairOrderId String
  shopFeeId     String

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  shopFee     ShopFee     @relation(fields: [shopFeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([repairOrderId, shopFeeId])
  @@index([repairOrderId])
  @@index([shopFeeId])
}

// Landing-page content blocks (legacy – kept for migration history).
model LandingBlock {
  id        String  @id @default(cuid())
  type      String
  content   String  @default("")
  imageData String?
  x         Float   @default(0)
  y         Float   @default(0)
  width     Float   @default(400)
  height    Float   @default(100)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

// Rich-text landing page content (singleton row, id = "singleton").
// Legacy — the /site website builder was removed; kept for migration history.
model LandingContent {
  id        String   @id @default("singleton")
  html      String   @default("")
  theme     String   @default("{}")
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Multi-tenancy: each Organization is one business (tenant). Users are logins
// that belong to an Organization. A platform owner (role SUPERADMIN) has no
// Organization and manages all of them.
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String // the business's own shop name, shown to its users
  // ACTIVE | SUSPENDED — a suspended org's users can't sign in (e.g. unpaid).
  status    String   @default("ACTIVE")
  accountType String  @default("AUTO_SHOP")
  features   String[] @default([])

  // --- Billing (Stripe subscription) ---------------------------------------
  // Contact email used for the Stripe customer / receipts.
  billingEmail         String?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  // Mirrors the Stripe subscription status: trialing | active | past_due |
  // canceled | unpaid | incomplete (null before checkout completes).
  subscriptionStatus   String?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  // First moment we saw the subscription go unpaid/past_due. Cleared on a
  // successful payment. Drives the grace period before auto-suspension.
  pastDueSince         DateTime?

  // --- Stripe Connect (let this shop's customers pay it online) ------------
  // The shop's own connected Stripe account (acct_…). Funds from customer
  // invoice payments land here and pay out to the shop's bank — never to the
  // platform. chargesEnabled mirrors the connected account's charges_enabled;
  // the Pay button only shows once it's true.
  stripeConnectAccountId       String?  @unique
  stripeConnectChargesEnabled  Boolean  @default(false)
  stripeConnectDetailsSubmitted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  customers        Customer[]
  vehicles         Vehicle[]
  repairOrders     RepairOrder[]
  payments         Payment[]
  technicians      Technician[]
  parts            Part[]
  appointments     Appointment[]
  calendarEvents   CalendarEvent[]
  repairNotes      RepairNote[]
  cannedJobs       CannedJob[]
  expenses         Expense[]
  shopFees         ShopFee[]
  shopSettings     ShopSetting[]

  @@index([status])
}

model CalendarEvent {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title        String
  startsAt     DateTime
  endsAt       DateTime?
  allDay       Boolean      @default(false)
  isReminder   Boolean      @default(false)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([orgId])
  @@index([startsAt])
}

model User {
  id           String        @id @default(cuid())
  // Null only for a platform SUPERADMIN (M.S.A.M Enterprise staff).
  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  username     String  @unique
  usernameLower String @unique
  // Optional contact email. Captured for OWNERs at signup (the billing email)
  // so they can self-serve a password reset. Not unique: staff logins may share
  // a shop inbox, and it's only used to deliver reset links.
  email        String?
  passwordHash String
  // SUPERADMIN | OWNER | ADMIN | STAFF
  role         String  @default("STAFF")
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordResetTokens PasswordResetToken[]

  @@index([orgId])
}

// Contact / demo requests captured by the public marketing landing page
// (src/components/marketing/VultrixLanding.jsx via /api/leads). Not tenant
// data — these are prospective customers, so there is no orgId scoping.
model MarketingLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  shop      String   @default("")
  phone     String   @default("")
  message   String   @default("")
  source    String   @default("contact")
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Single-use, time-limited password reset tokens. We store only a SHA-256 hash
// of the token; the raw token lives solely in the emailed reset link. A token
// is valid until expiresAt and only while usedAt is null.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  // Wrong-guess counter for the 6-digit code; the code is invalidated after a
  // small number of incorrect attempts to make brute-forcing infeasible.
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Photos attached to a repair order (before/after shots for insurance claims
// and documentation). The image is stored as a client-resized JPEG data URL —
// same lightweight approach as the customer signature — so there's no external
// object storage dependency. Cascades away with its repair order.
model RepairOrderPhoto {
  id            String      @id @default(cuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  // Denormalized org id for fast, safe tenant-scoped queries.
  orgId         String
  dataUrl       String      // base64 data URL (resized/compressed JPEG)
  caption       String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([repairOrderId])
  @@index([orgId])
}
